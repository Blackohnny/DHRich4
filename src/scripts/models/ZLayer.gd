class_name ZLayer

## 統一管理遊戲中所有節點的 Z-Index (前後覆蓋圖層順序)
## 數字越大，圖層越上方 (越不會被蓋住)。
enum {
	BOARD = 0,            # [0] 底層地圖格子與連線
	CELL_ICON = 10,       # [10] 格子外側的建築圖示、擁有者標籤 (房屋/商店招牌)
	PLAYER_INACTIVE = 20, # [20] 休息中(未行動)的玩家棋子
	PLAYER_ACTIVE = 30,   # [30] 當前正在行動回合的玩家棋子 (保證蓋在別的棋子上面)
	UI_OVERLAY = 100      # [100] 最上層彈出視窗 (對話框、教學等)
}
