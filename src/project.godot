; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DHRich4"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/icon.svg"

[autoload]

DebugLogger="*res://scripts/DebugLogger.gd"
EventProcessor="*res://scripts/EventProcessor.gd"
SettingsManager="*res://scripts/SettingsManager.gd"
ResourceManager="*res://scripts/ResourceManager.gd"
AIManager="*res://scripts/AIManager.gd"
PlayerManager="*res://scripts/PlayerManager.gd"
NewsManager="*res://scripts/NewsManager.gd"

[debug]

file_logging/enable_file_logging=true
file_logging/log_path="res://logs/godot.log"

[display]

window/size/window_width_override=1280
window/size/window_height_override=720
window/subwindows/embed_subwindows=false

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
